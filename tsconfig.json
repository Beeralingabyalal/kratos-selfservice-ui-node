{
  "compilerOptions": {
    "declaration": true,
    "resolveJsonModule": true,
    "target": "es5",
    "module": "commonjs",
    "lib": ["es2019", "dom"],
    "outDir": "./lib",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "include": ["src", "test"],
  "exclude": ["contrib"]
}
