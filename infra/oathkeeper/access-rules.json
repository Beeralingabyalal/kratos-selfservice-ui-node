[
  {
    "id": "ai-gateway-jwt-access",
    "match": {
      "url": "http://localhost:4455/ai/<.*>",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
    },
    "authenticators": [
      {
        "handler": "jwt"
      }
    ],
    "authorizer": {
      "handler": "allow"
    },
    "mutators": [
      {
        "handler": "header",
        "config": {
          "headers": {
            "x-auth-subject": "{{ print .Subject }}"
          }
        }
      }
    ],
    "upstream": {
      "url": "http://ai-gateway:4000"
    }
  },
  {
