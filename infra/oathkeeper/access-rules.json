  {
    "id": "dicom-deid-jwt-access",
    "match": {
      "url": "http://localhost:4455/dicom/<.*>",
      "methods": ["GET", "POST", "OPTIONS"]
    },
    "authenticators": [
      {
        "handler": "jwt"
      }
    ],
    "authorizer": {
      "handler": "allow"
    },
    "mutators": [
      {
        "handler": "header",
        "config": {
          "headers": {
            "x-auth-subject": "{{ print .Subject }}",
            "x-tenant-id": "{{ if index .Extra \"tenant_id\" }}{{ print (index .Extra \"tenant_id\") }}{{ else }}{{ print (index (index .Extra \"ext\") \"tenant_id\") }}{{ end }}"
          }
        }
      }
    ],
    "upstream": {
      "url": "http://dicom-deid:4040"
    }
  },
