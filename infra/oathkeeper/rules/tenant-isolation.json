[
  {
    "id": "tenant-rule",
    "match": {
      "url": "<http|https>://<.*>/api/tenant/<.*>",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"]
    },
    "upstream": {
      "url": "http://authz_adapter:3001",
      "preserve_host": true
    },
    "authenticators": [
      { "handler": "cookie_session" }
    ],
    "authorizer": {
      "handler": "keto_engine_acp_ory",
      "config": {
        "base_url": "http://keto:4466",
        "required_action": "admin",
        "required_resource": "tenant"
      }
    },
    "mutators": [
      { "handler": "noop" }
    ]
  }
]